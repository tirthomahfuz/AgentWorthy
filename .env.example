# =============================================================================
# Agentworthy Environment Variables
# Copy to .env and fill in values for local development
# =============================================================================

# --- Database ---
# PostgreSQL connection string for API and worker
DATABASE_URL=postgresql://agentworthy:agentworthy@localhost:5432/agentworthy

# --- Redis ---
# Redis URL for RQ job queue and rate limiting
REDIS_URL=redis://localhost:6379/0

# --- API ---
# Secret key for signing tokens (generate with: openssl rand -hex 32)
API_SECRET_KEY=change-me-in-production
# Public URL of the FastAPI backend (used by web app)
API_URL=http://localhost:8000
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# --- Web (Next.js) ---
# Public API URL exposed to browser
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Worker ---
# Max concurrent scan jobs globally
WORKER_CONCURRENCY=2
# Local path for simulation screenshots (Phase 3+)
SCREENSHOT_PATH=/data/screenshots

# --- Anthropic (Phase 3+) ---
# API key for LLM agent simulation and fix generation
ANTHROPIC_API_KEY=

# --- Auth (Phase 2) ---
# NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=dev-nextauth-secret-change-in-production
NEXTAUTH_URL=http://localhost:3000
# Google OAuth credentials (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set to "true" when Google OAuth credentials are configured
NEXT_PUBLIC_GOOGLE_ENABLED=false

# --- Email (Phase 2) ---
# Resend API key for magic link emails. If absent, dev mode logs sign-in URL to console.
RESEND_API_KEY=
EMAIL_FROM=Agentworthy <onboarding@agentworthy.dev>

# --- Stripe (Phase 5+) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=
